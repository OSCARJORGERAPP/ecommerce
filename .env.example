# MongoDB local (en la plataforma de la academia se inyectan en su lugar
# MONGO_HOST/MONGO_PORT/MONGO_USER/MONGO_PASSWORD/MONGO_DB — el código acepta ambas)
# 127.0.0.1 (IPv4) mejor que "localhost": localhost puede resolver a ::1 y caer
# en otro mongod si hay varios (ver RETROSPECTIVA)
MONGODB_URI=mongodb://127.0.0.1:27017

# Marca white-label (opcionales; por defecto "Electronics" — ver lib/brand.ts)
# BRAND_NAME=Mi Tienda
# BRAND_TAGLINE=El lema de mi empresa
# BRAND_DESCRIPTION=Descripción corta que aparece en el hero y en el <title>
# BRAND_ADDRESS=Calle Mayor 1, Madrid
# BRAND_EMAIL=hola@mitienda.com
# BRAND_PHONE=+34 600 000 000
# BRAND_WHATSAPP=34600000000        # solo dígitos con prefijo de país (enlace wa.me)
# BRAND_HOURS=Lun–Vie 9:00–18:00

# Secreto para firmar los JWT de sesión (cookie httpOnly)
AUTH_SECRET=un-secreto-largo-y-aleatorio

# Stripe (cuenta de prueba: https://dashboard.stripe.com/test)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
